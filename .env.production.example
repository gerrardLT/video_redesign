# =============================================
# 生产环境变量（复制为 .env.production 并填入真实值）
# =============================================

# Database（PostgreSQL）
DATABASE_URL="postgresql://postgres:password@postgres:5432/video_redesign"

# Redis（Docker 内部网络）
REDIS_URL="redis://redis:6379"

# Authentication（生产必须替换为强随机值）
JWT_SECRET="替换为32位以上随机字符串"

# 平台账号会话凭证加密密钥（platform-metrics-crawler 用 AES-256-GCM 加密商家平台 cookie）
# 生产必须替换为强随机值；缺失时凭证加解密直接抛错（禁止明文存储、禁止默认回退密钥）
PLATFORM_CRED_ENC_KEY="替换为32位以上随机字符串"

# 火山引擎方舟平台（Seedance 2.0 视频生成）
SEEDANCE_API_KEY="ark-your-api-key"
SEEDANCE_API_URL="https://ark.cn-beijing.volces.com/api/v3"

# 视频多模态分析（qwen-vl / doubao-seed 等）
VISION_API_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
VISION_API_KEY="your-vision-api-key"
VISION_MODEL="qwen-vl-max"

# 方舟文生图（人物锚定图生成）
ARK_API_KEY="your-ark-api-key"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# Object Storage (阿里云 OSS)
OSS_REGION="oss-cn-shanghai"
OSS_ACCESS_KEY_ID="your-access-key-id"
OSS_ACCESS_KEY_SECRET="your-access-key-secret"
OSS_BUCKET="your-bucket-name"
OSS_ENDPOINT="https://oss-cn-shanghai.aliyuncs.com"
OSS_CDN_DOMAIN="https://your-bucket.oss-cn-shanghai.aliyuncs.com"

# OSS 传输加速 endpoint（可选）：仅用于送火山方舟拉取视频做分析。
# 当 OSS bucket 在境外（如新加坡 oss-ap-southeast-1）、方舟服务器在境内时，
# 方舟直接拉境外直链会跨境超时；配置此项后，分析专用 URL 走传输加速域名避免超时。
# 需先在 OSS 控制台开启「传输加速」。留空则不启用（不影响其它功能）。
# 全球加速填：oss-accelerate.aliyuncs.com
OSS_ACCELERATE_ENDPOINT="oss-accelerate.aliyuncs.com"

# App
NEXT_PUBLIC_APP_URL="https://你的域名.com"
NODE_ENV="production"

# 场景检测阈值
SCENE_THRESHOLD="0.32"

# WaveSpeed AI Video Upscaler（视频超分服务）
WAVESPEED_API_KEY="wsk_live_wg15Ugpu39M9iP3oMGiFxMGwqk7jppKJm71nl1pRN8o"
WAVESPEED_API_BASE_URL="https://api.wavespeed.ai/api/v3"

# 阿里云百炼 DashScope（HappyHorse V-Edit 视频编辑模型）
DASHSCOPE_API_KEY="your-dashscope-api-key"
# HappyHorse 积分系数（平台加成，默认 1.5）
HAPPYHORSE_CREDIT_COEFFICIENT="1.5"
