// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================
// 用户表
// ========================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  nickname      String?
  creditBalance Int       @default(100) @map("credit_balance")
  role          String    @default("USER") // USER | ADMIN
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  projects            Project[]
  jobs                GenerationJob[]
  ledger              CreditLedger[]
  orders              PackageOrder[]
  assets              Asset[]
  notifications       Notification[]
  onboardingProgress  OnboardingProgress?
  subscriptionRecords SubscriptionRecord[]
  subscriptionOrders  SubscriptionOrder[]
  conversations       Conversation[]

  @@map("users")
}

// ========================
// 项目表
// ========================
model Project {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  videoUrl    String?  @map("video_url")
  coverUrl    String?  @map("cover_url")
  status      String   @default("UPLOADING") // UPLOADING|DOWNLOADING|PARSING|EDITABLE|GENERATING|EXPORTED|MERGE_FAILED|FAILED
  duration    Float?
  aspectRatio String?  @map("aspect_ratio")
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // 导出超分相关字段
  exportStatus     String?   @map("export_status") // MERGING | UPSCALING | COMPLETED | FAILED
  exportResolution String?   @map("export_resolution") // 480p | 720p | 1080p
  exportVideoUrl   String?   @map("export_video_url") // 最终导出视频 URL
  exportError      String?   @map("export_error") // 导出失败原因
  exportCreatedAt  DateTime? @map("export_created_at") // 导出任务创建时间

  engine String  @default("seedance") @map("engine") // 生成引擎: seedance | happyhorse
  bgmKey String? @map("bgm_key") // 自定义背景音乐 OSS 键

  isSample Boolean @default(false) @map("is_sample") // 标记是否为新手引导示例项目

  conversationId String? @map("conversation_id") // 来源对话会话（对话式 C 端触发的生成，可空）

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shots        Shot[]
  shotGroups   ShotGroup[] // 分镜组反向关系
  characters   Character[]
  assets       Asset[]
  styleConfig  StyleConfig?
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([conversationId])
  @@map("projects")
}

// ========================
// 分镜表
// ========================
model Shot {
  id                   String   @id @default(cuid())
  projectId            String   @map("project_id")
  orderIndex           Int      @map("order_index")
  startTime            Float    @map("start_time")
  endTime              Float    @map("end_time")
  coverUrl             String?  @map("cover_url")
  scene                String?
  shotType             String?  @map("shot_type")
  cameraMove           String?  @map("camera_move")
  dialogue             String? // JSON 字符串，存储对话/台词信息
  audioDesc            String?  @map("audio_desc")
  prompt               String?
  genStatus            String   @default("PENDING") @map("gen_status") // PENDING|QUEUED|GENERATING|SUCCEEDED|FAILED|CANCELED
  genVideoUrl          String?  @map("gen_video_url")
  hasFace              Boolean  @default(true) @map("has_face")
  shotGroupId          String?  @map("shot_group_id") // 新增可空：归属的分镜组
  characterAppearances String?  @map("character_appearances") // 角色外观描述 JSON，格式: [{name: string, appearance: {hair, clothing, accessories, makeup}}]
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shotGroup  ShotGroup?      @relation(fields: [shotGroupId], references: [id], onDelete: SetNull)
  shotAssets ShotAsset[]
  jobs       GenerationJob[]

  @@index([projectId])
  @@index([shotGroupId])
  @@map("shots")
}

// ========================
// 分镜组表（新增）
// 一个分镜组对应一次 Seedance 生成调用与一段合并视频
// ========================
model ShotGroup {
  id                 String   @id @default(cuid())
  projectId          String   @map("project_id")
  groupIndex         Int      @map("group_index") // Project 内唯一，从 0 起连续递增
  genDuration        Float    @map("gen_duration") // 0.01 ~ 15.00 秒
  startTime          Float    @map("start_time") // 组内首个 Shot 的 startTime
  endTime            Float    @map("end_time") // 组内末个 Shot 的 endTime
  genStatus          String   @default("PENDING") @map("gen_status") // PENDING|QUEUED|GENERATING|SUCCEEDED|FAILED|CANCELED
  genVideoUrl        String?  @map("gen_video_url") // 未生成时为空
  genCoverUrl        String?  @map("gen_cover_url") // 生成视频封面 URL（从 genVideoUrl 抽帧持久化，用于前端 poster 展示）
  lastFrameUrl       String?  @map("last_frame_url") // 本组生成成功时 Seedance 返回的受信尾帧 URL（returnLastFrame=true 时有值），供后续同场景承接复用
  audioKey           String?  @map("audio_key") // group_{groupIndex}.mp3 的 OSS 键
  clipVideoUrl       String?  @map("clip_video_url") // 按组裁切的视频片段 OSS URL（修复风险14）
  timelineScript     String?  @map("timeline_script") // 最近一次合并的 Timeline_Script 快照
  scriptEdited       Boolean  @default(false) @map("script_edited") // 用户是否手动编辑过脚本：true 固定复用 timelineScript；false 每次按最新规则重合并（含对白/台词）
  scriptHash         String?  @map("script_hash") // 最近一次生成请求的幂等哈希
  backgroundImageUrl String?  @map("background_image_url") // Seedance 模式背景图 OSS URL
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shots           Shot[]
  jobs            GenerationJob[]
  groupCharacters ShotGroupCharacter[]
  versions        GenerationVersion[] // 版本历史反向关系

  @@unique([projectId, groupIndex])
  @@index([projectId])
  @@map("shot_groups")
}

// ========================
// 分镜组 ↔ 人物 关联表
// 每个分镜组可选择性包含若干人物（默认 = 该组镜头中实际出现的人物，用户可增删）
// 生成时仅注入本组选中人物的锚定图作 reference_image
// ========================
model ShotGroupCharacter {
  id          String   @id @default(cuid())
  shotGroupId String   @map("shot_group_id")
  characterId String   @map("character_id")
  createdAt   DateTime @default(now()) @map("created_at")

  shotGroup ShotGroup @relation(fields: [shotGroupId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([shotGroupId, characterId])
  @@index([shotGroupId])
  @@index([characterId])
  @@map("shot_group_characters")
}

// ========================
// 人物表
// ========================
model Character {
  id             String   @id @default(cuid())
  projectId      String   @map("project_id")
  name           String
  appearance     String?
  enabled        Boolean  @default(true)
  imageUrl       String?  @map("image_url")
  avatarAssetUrl String?  @map("avatar_asset_url") // asset://asset-xxxxx 格式
  avatarGroupId  String?  @map("avatar_group_id") // 素材组 ID
  avatarAssetId  String?  @map("avatar_asset_id") // 素材 ID
  avatarStatus   String   @default("NONE") @map("avatar_status") // NONE | REGISTERING | ACTIVE | FAILED
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project    Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groupLinks ShotGroupCharacter[]

  @@index([projectId])
  @@map("characters")
}

// ========================
// 素材表（资产库扩展：支持用户级跨项目资产管理）
// ========================
model Asset {
  id           String    @id @default(cuid())
  projectId    String?   @map("project_id") // 可选：用户级资产可不绑定项目
  userId       String    @map("user_id")
  type         String // CHARACTER_IMAGE | UPLOADED_IMAGE | AI_GENERATED
  category     String?   @map("category") // 资产库分类: CHARACTER | MATERIAL | AUDIO
  displayName  String?   @map("display_name") // 资产显示名称（用于搜索和展示）
  url          String
  thumbUrl     String?   @map("thumb_url")
  fileName     String?   @map("file_name")
  fileSize     Int?      @map("file_size")
  isCharImage  Boolean   @default(false) @map("is_char_image")
  sortOrder    Int       @default(0) @map("sort_order")
  status       String    @default("PENDING") // PENDING | UPLOADED | FAILED | EXPIRED | CHECKING | APPROVED | REJECTED | CHECK_FAILED
  rejectReason String?   @map("reject_reason") // 人脸检测拒绝原因
  expiresAt    DateTime? @map("expires_at") // 过期时间，AI 生成资产创建时设置为 +14 天
  createdAt    DateTime  @default(now()) @map("created_at")

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shotAssets ShotAsset[]

  @@index([projectId])
  @@index([userId]) // 按用户查询索引
  @@index([userId, category]) // 按用户+分类复合索引
  @@map("assets")
}

// ========================
// 分镜-素材关联表
// ========================
model ShotAsset {
  id         String   @id @default(cuid())
  shotId     String   @map("shot_id")
  assetId    String   @map("asset_id")
  displayNum Int      @map("display_num") // [图N] 中的 N
  sortOrder  Int      @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  shot  Shot  @relation(fields: [shotId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([shotId, assetId])
  @@map("shot_assets")
}

// ========================
// 生成任务表
// ========================
model GenerationJob {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  projectId      String   @map("project_id")
  shotId         String?  @map("shot_id") // 由必填改为可空：按组任务无 shotId
  shotGroupId    String?  @map("shot_group_id") // 新增可空：归属的分镜组
  status         String   @default("CREATED") // CREATED|QUEUED|CREDIT_RESERVED|SUBMITTED|GENERATING|SUCCEEDED|FAILED|CANCELED|REFUNDED
  promptSnapshot String?  @map("prompt_snapshot")
  assetSnapshot  String?  @map("asset_snapshot") // JSON 字符串
  duration       Int      @default(5)
  aspectRatio    String   @default("16:9") @map("aspect_ratio")
  resolution     String   @default("480p")
  seedanceTaskId String?  @map("seedance_task_id")
  resultVideoUrl String?  @map("result_video_url")
  errorCode      String?  @map("error_code")
  errorMessage   String?  @map("error_message")
  engine         String   @default("seedance") @map("engine") // 生成引擎: seedance | happyhorse
  segmentIndex   Int?     @map("segment_index") // HappyHorse 分段索引（0-based）
  totalSegments  Int?     @map("total_segments") // HappyHorse 总分段数
  costEstimate   Int?     @map("cost_estimate")
  retryCount     Int      @default(0) @map("retry_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user      User               @relation(fields: [userId], references: [id])
  shot      Shot?              @relation(fields: [shotId], references: [id], onDelete: SetNull)
  shotGroup ShotGroup?         @relation(fields: [shotGroupId], references: [id], onDelete: SetNull)
  ledger    CreditLedger[]
  version   GenerationVersion? // 版本历史反向关系（1:1，一个 job 最多产生一个 version）

  @@index([userId])
  @@index([shotId])
  @@index([shotGroupId])
  @@index([status])
  @@map("generation_jobs")
}

// ========================
// 积分流水表
// ========================
model CreditLedger {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  jobId               String?  @map("job_id")
  orderId             String?  @map("order_id") // 充值订单关联
  projectId           String?  @map("project_id") // 解析阶段扣费关联（无 GenerationJob 时使用）
  subscriptionOrderId String?  @map("subscription_order_id") // 订阅积分发放关联
  bizRefType          String?  @map("biz_ref_type") // 商家操作实体关联类型：CONTENT_BRIEF | CONTENT_PLAN | STORE（可空、无外键）
  bizRefId            String?  @map("biz_ref_id") // 对应商家实体主键（无外键约束，避免 jobId 外键违约）
  action              String // RESERVE | CHARGE | REFUND | TOPUP | ADMIN_ADJUST | SUBSCRIPTION_GRANT
  amount              Int // 正数为增加，负数为减少
  balanceAfter        Int      @map("balance_after")
  remark              String?
  createdAt           DateTime @default(now()) @map("created_at")

  user              User               @relation(fields: [userId], references: [id])
  job               GenerationJob?     @relation(fields: [jobId], references: [id])
  order             PackageOrder?      @relation(fields: [orderId], references: [id])
  subscriptionOrder SubscriptionOrder? @relation(fields: [subscriptionOrderId], references: [id])

  @@index([userId])
  @@index([jobId])
  @@index([orderId])
  @@index([projectId])
  @@index([subscriptionOrderId])
  @@index([bizRefType, bizRefId]) // 按商家实体关联键查询 / 幂等检查
  @@map("credit_ledger")
}

// ========================
// 套餐定义表（种子数据）
// ========================
model Package {
  id          String   @id @default(cuid())
  name        String // 体验包、基础包等
  credits     Int // 积分数量
  price       Int // 价格（分）
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  orders PackageOrder[]

  @@map("packages")
}

// ========================
// 套餐订单表
// ========================
model PackageOrder {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  packageId     String    @map("package_id")
  amount        Int // 支付金额（分）
  credits       Int // 到账积分数
  status        String    @default("PENDING") // PENDING | PAID | EXPIRED | REQUIRES_MANUAL_REVIEW
  payMethod     String    @map("pay_method") // wechat | alipay
  transactionId String?   @map("transaction_id") // 支付平台交易号
  paidAt        DateTime? @map("paid_at")
  expireAt      DateTime  @map("expire_at") // 订单超时时间（30分钟）
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user    User           @relation(fields: [userId], references: [id])
  package Package        @relation(fields: [packageId], references: [id])
  ledger  CreditLedger[]

  @@index([userId])
  @@index([status])
  @@map("package_orders")
}

// ========================
// 画面风格配置表
// ========================
model StyleConfig {
  id                String   @id @default(cuid())
  projectId         String   @unique @map("project_id")
  templateId        String?  @map("template_id")
  customDescription String?  @map("custom_description") // 扁平文本版风格描述（向后兼容 merger 读取）
  structuredStyle   String?  @map("structured_style") // 结构化 JSON：{artStyle, colorTone, characters: [{name, appearance, props}], subtitleDeclaration}
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  project  Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template StyleTemplate? @relation(fields: [templateId], references: [id])

  @@map("style_configs")
}

// ========================
// 风格模板表（种子数据）
// ========================
model StyleTemplate {
  id           String   @id @default(cuid())
  name         String // 写实、动漫、3D 等
  description  String?
  thumbnailUrl String?  @map("thumbnail_url")
  promptPrefix String   @map("prompt_prefix") // 融合到 prompt 的前缀片段
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  configs StyleConfig[]

  @@map("style_templates")
}

// ========================
// 站内通知表
// ========================
model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String // ASSET_EXPIRING | PAYMENT_SUCCESS | SYSTEM
  title     String
  content   String
  meta      String? // JSON，存放额外跳转信息
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ========================
// 案例展示表
// ========================
model CaseItem {
  id                String   @id @default(cuid())
  title             String
  description       String
  category          String // 口播IP、说车试驾、短剧网红、高端探店、体育解说、装修探房、农村生活、美食探店
  coverUrl          String   @map("cover_url")
  originalVideoUrl  String   @map("original_video_url")
  generatedVideoUrl String   @map("generated_video_url")
  isPublished       Boolean  @default(false) @map("is_published")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([isPublished])
  @@map("case_items")
}

// ========================
// 帮助文章表
// ========================
model HelpArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique // URL 友好标识
  section     String // quick_start | detailed_guide | faq
  content     String // Markdown 正文
  sortOrder   Int      @default(0) @map("sort_order")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([section])
  @@index([isPublished])
  @@map("help_articles")
}

// ========================
// 内容安全审核记录表
// ========================
model ContentSafetyLog {
  id         String    @id @default(cuid())
  assetId    String    @map("asset_id")
  userId     String    @map("user_id")
  checkType  String    @default("face_detection") @map("check_type") // face_detection
  result     String // pass | reject | error
  detail     String? // JSON detail from API
  reviewedBy String?   @map("reviewed_by") // admin userId if manually reviewed
  reviewedAt DateTime? @map("reviewed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([assetId])
  @@index([userId])
  @@index([result])
  @@map("content_safety_logs")
}

// ========================
// 视频下载任务表
// ========================
model VideoDownloadTask {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  sourceUrl String   @map("source_url") // 原始分享链接
  platform  String // douyin | kuaishou | weixin
  status    String   @default("PENDING") // PENDING | DOWNLOADING | COMPLETED | FAILED
  progress  Int      @default(0) // 0-100
  errorMsg  String?  @map("error_msg")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@map("video_download_tasks")
}

// ========================
// 生成版本记录表
// 每条记录对应一次成功的视频生成结果快照，用于版本历史管理
// ========================
model GenerationVersion {
  id              String   @id @default(cuid())
  shotGroupId     String   @map("shot_group_id")
  generationJobId String   @unique @map("generation_job_id")
  versionNumber   Int      @map("version_number") // 组内顺序号，从 1 开始递增
  videoUrl        String   @map("video_url") // OSS 视频 URL
  coverUrl        String?  @map("cover_url") // 封面 URL
  lastFrameUrl    String?  @map("last_frame_url") // 尾帧 URL
  promptSnapshot  String   @map("prompt_snapshot") // 生成时使用的完整 prompt
  costEstimate    Int      @map("cost_estimate") // 本次生成消耗的积分
  isCurrent       Boolean  @default(false) @map("is_current") // 是否为当前使用版本
  createdAt       DateTime @default(now()) @map("created_at")

  shotGroup     ShotGroup     @relation(fields: [shotGroupId], references: [id], onDelete: Cascade)
  generationJob GenerationJob @relation(fields: [generationJobId], references: [id])

  @@unique([shotGroupId, versionNumber])
  @@index([shotGroupId])
  @@index([generationJobId])
  @@map("generation_versions")
}

// ========================
// 新手引导进度表
// 存储每个用户的引导步骤完成/跳过状态，用于跨设备同步引导进度
// ========================
model OnboardingProgress {
  id                String   @id @default(cuid())
  userId            String   @unique @map("user_id")
  welcomeWizard     String   @default("NOT_COMPLETED") @map("welcome_wizard") // 欢迎向导步骤状态
  sampleProject     String   @default("NOT_COMPLETED") @map("sample_project") // 示例项目创建步骤状态
  dashboardTooltip  String   @default("NOT_COMPLETED") @map("dashboard_tooltip") // Dashboard 提示引导状态
  editorGuide       String   @default("NOT_COMPLETED") @map("editor_guide") // 编辑器引导状态
  firstProjectGuide String   @default("NOT_COMPLETED") @map("first_project_guide") // 首次创建项目引导状态
  rewardGranted     Boolean  @default(false) @map("reward_granted") // 是否已发放完成奖励
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("onboarding_progress")
}

// ========================
// 订阅套餐定义表（种子数据）
// ========================
model SubscriptionPlan {
  id             String   @id @default(cuid())
  name           String // 月卡会员、年卡会员
  type           String // monthly | yearly
  price          Int // 价格（分）：月卡2990，年卡24900
  monthlyCredits Int      @map("monthly_credits") // 每月到账积分：500
  bonusCredits   Int      @default(0) @map("bonus_credits") // 额外奖励积分（年卡1000）
  description    String?
  privileges     String // JSON: 特权描述列表
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  records SubscriptionRecord[]
  orders  SubscriptionOrder[]

  @@map("subscription_plans")
}

// ========================
// 用户订阅记录表
// ========================
model SubscriptionRecord {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")
  planId              String    @map("plan_id")
  status              String    @default("ACTIVE") // ACTIVE | CANCELED | EXPIRED
  renewalType         String    @default("AUTO") @map("renewal_type") // AUTO | MANUAL | CANCELED
  contractId          String?   @map("contract_id") // 支付平台签约协议编号
  payMethod           String    @map("pay_method") // wechat | alipay
  startDate           DateTime  @map("start_date") // 订阅开始日期
  endDate             DateTime  @map("end_date") // 当期到期日期
  lastRenewalDate     DateTime? @map("last_renewal_date") // 最近一次续费日期
  totalCreditsGranted Int       @default(0) @map("total_credits_granted") // 累计已发放积分
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user   User                @relation(fields: [userId], references: [id])
  plan   SubscriptionPlan    @relation(fields: [planId], references: [id])
  orders SubscriptionOrder[]

  @@index([userId])
  @@index([status])
  @@index([endDate])
  @@map("subscription_records")
}

// ========================
// 订阅订单表
// ========================
model SubscriptionOrder {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  planId        String    @map("plan_id")
  recordId      String?   @map("record_id") // 续费时关联已有记录
  type          String // FIRST_SUBSCRIBE | RENEWAL | MANUAL_RENEWAL
  amount        Int // 支付金额（分）
  credits       Int // 本次应发放积分
  status        String    @default("PENDING") // PENDING | PAID | FAILED | EXPIRED
  payMethod     String    @map("pay_method") // wechat | alipay
  transactionId String?   @map("transaction_id") // 支付平台交易号
  contractId    String?   @map("contract_id") // 签约协议编号
  paidAt        DateTime? @map("paid_at")
  expireAt      DateTime  @map("expire_at") // 订单超时时间（30分钟）
  failReason    String?   @map("fail_reason") // 扣款失败原因
  retryCount    Int       @default(0) @map("retry_count") // 扣款重试次数
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user          User                @relation(fields: [userId], references: [id])
  plan          SubscriptionPlan    @relation(fields: [planId], references: [id])
  record        SubscriptionRecord? @relation(fields: [recordId], references: [id])
  creditLedgers CreditLedger[]

  @@index([userId])
  @@index([recordId])
  @@index([status])
  @@map("subscription_orders")
}

// ================================================================
// ============ 本地生活营销平台 - 新增枚举与模型 ============
// ============ (增量添加，不修改/删除现有表结构) ============
// ================================================================

// ============ 枚举 ============

enum MerchantIndustry {
  RESTAURANT
  DRINK
  BAKERY
  CAFE
  HOTPOT
  BBQ
  FAST_FOOD
  OTHER_LOCAL
}

enum ContentGoal {
  TRAFFIC
  PROMOTION
  NEW_PRODUCT
  TRUST_BUILDING
  BRAND_STORY
  CUSTOMER_TESTIMONIAL
  WEEKEND_BOOST
  REPEAT_PURCHASE
}

enum ContentBriefStatus {
  DRAFT
  READY_TO_SHOOT
  MATERIALS_UPLOADED
  RENDERING
  GENERATED
  COMPLIANCE_REVIEW
  READY_TO_EXPORT
  EXPORTED
  PUBLISHED
  FAILED
  ARCHIVED
}

enum ShotTaskType {
  STOREFRONT
  PRODUCT_CLOSEUP
  COOKING_PROCESS
  STAFF_ACTION
  CUSTOMER_REACTION
  OWNER_TALKING
  ENVIRONMENT
  OFFER_DISPLAY
  CTA_SCREEN
  AI_GENERATED_FILLER
}

enum VideoVariantType {
  PROMOTION
  ATMOSPHERE
  OWNER_TALKING
  TRUST
  PRODUCT
}

/// 创作模式 — Inhot 四模式
enum CreationMode {
  REPLICATE_TRENDING  // 复刻爆款
  IMMERSIVE_SHORT     // 沉浸式短片
  INSPIRE_TO_VIDEO    // 灵感生视频
  PHOTO_ANIMATE       // 照片跟我动
}

enum ComplianceRiskLevel {
  LOW
  MEDIUM
  HIGH
  BLOCKED
}

enum PublishPlatform {
  DOUYIN
  KUAISHOU
  XIAOHONGSHU
  WECHAT_CHANNELS
  MANUAL_EXPORT
}

enum PublishJobStatus {
  DRAFT
  READY
  EXPORTING
  EXPORTED
  PUBLISHING
  PUBLISHED
  FAILED
}

// ============ 商家与门店 ============

/// 商家实体，关联用户账号
model Merchant {
  id          String           @id @default(cuid())
  userId      String           @unique // 关联现有 User 表，一个用户只能有一个商家身份
  name        String
  contactName String?
  phone       String?
  industry    MerchantIndustry
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  stores Store[]

  @@index([userId])
  @@index([industry])
  @@map("merchants")
}

/// 门店实体，包含地址、行业、主打产品等经营信息
model Store {
  id                String           @id @default(cuid())
  merchantId        String
  name              String
  industry          MerchantIndustry
  city              String?
  district          String?
  businessArea      String?
  address           String?
  avgTicket         Int? // 客单价，分为单位
  openingHours      String?
  phone             String?
  mainProducts      Json // string[] - 主打产品列表
  mainSellingPoints Json // string[] - 主要卖点列表
  targetCustomers   Json? // string[] - 目标客群
  brandTone         String?
  canShootKitchen   Boolean          @default(false)
  canShootStaff     Boolean          @default(true)
  canShootCustomers Boolean          @default(false)
  hasGroupBuying    Boolean          @default(false)
  hasReservation    Boolean          @default(false)
  status            String           @default("ACTIVE") // ACTIVE | PROFILE_PENDING
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  merchant       Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  profile        StoreProfile?
  offers         ProductOffer[]
  contentPlans   ContentPlan[]
  contentBriefs  ContentBrief[]
  rawAssets      RawAsset[]
  consentRecords ConsentRecord[]
  socialAccounts SocialAccount[]

  @@index([merchantId])
  @@index([industry])
  @@index([city, district])
  @@map("stores")
}

// ============ 门店画像 ============

/// AI 生成的门店内容定位、人设、风格等策略信息
model StoreProfile {
  id                 String   @id @default(cuid())
  storeId            String   @unique
  contentPositioning String? // 内容定位描述
  recommendedPersona String? // 推荐人设
  contentDos         Json? // string[] - 内容推荐做的事
  contentDonts       Json? // string[] - 内容禁止做的事
  visualStyle        String? // 视觉风格
  hookKeywords       Json? // string[] - 钩子关键词（5-15个）
  forbiddenClaims    Json? // string[] - 违禁词列表（≥5个）
  preferredCta       Json? // string[] - 推荐 CTA（3-5个）
  weeklyCadence      Json? // { day: number, theme: string, count: number }[] - 每周发布节奏
  aiSummary          String? // LLM 生成的自然语言总结
  status             String   @default("COMPLETE") // COMPLETE | INCOMPLETE
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_profiles")
}

// ============ 商品/优惠 ============

/// 商品或优惠活动信息（套餐、折扣、团购等）
model ProductOffer {
  id            String    @id @default(cuid())
  storeId       String
  name          String
  description   String?
  originalPrice Int? // 原价，分为单位
  salePrice     Int? // 售价，分为单位
  validFrom     DateTime?
  validTo       DateTime?
  sellingPoints Json? // string[] - 卖点列表
  usageRules    String? // 使用规则说明
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([isActive])
  @@map("product_offers")
}

// ============ 行业剧本库 ============

/// 行业剧本模板，定义视频结构、镜头顺序和文案模板
model Playbook {
  id                  String           @id @default(cuid())
  industry            MerchantIndustry
  name                String
  goal                ContentGoal
  description         String?
  structure           Json // PlaybookSegment[] - 视频结构定义
  requiredShots       Json // ShotTaskType[] - 必拍镜头类型列表
  optionalShots       Json? // ShotTaskType[] - 可选镜头类型列表
  hookTemplates       Json // string[] - 钩子模板（带 {变量} 占位符）
  captionTemplates    Json // string[] - 文案模板
  coverTitleTemplates Json // string[] - 封面标题模板
  ctaTemplates        Json // string[] - CTA 模板
  complianceRules     Json? // 剧本级额外合规规则
  scoreWeight         Json? // { views: number, conversion: number } - 评分权重
  tierRequired        String           @default("FREE") // FREE | GROWTH - 所需订阅等级
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  contentBriefs ContentBrief[]

  @@index([industry])
  @@index([goal])
  @@index([isActive])
  @@map("playbooks")
}

// ============ 内容计划 ============

/// 内容计划，覆盖一段时间的每日内容安排
model ContentPlan {
  id        String   @id @default(cuid())
  storeId   String
  title     String
  startDate DateTime
  endDate   DateTime
  strategy  Json? // 生成策略元数据
  status    String   @default("ACTIVE") // ACTIVE | COMPLETED | CANCELLED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store  Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  briefs ContentBrief[]

  @@index([storeId])
  @@index([startDate, endDate])
  @@map("content_plans")
}

// ============ 内容任务 ============

/// 单条内容任务，对应一天的拍摄和生成目标
model ContentBrief {
  id                  String             @id @default(cuid())
  storeId             String
  contentPlanId       String?
  playbookId          String?
  title               String
  goal                ContentGoal
  scheduledDate       DateTime
  status              ContentBriefStatus @default(DRAFT)
  hook                String? // 钩子文案
  mainMessage         String? // 主要信息
  offerId             String? // 关联的优惠 ID
  suggestedCaption    String? // 建议文案
  suggestedTitle      String? // 建议标题
  suggestedCoverTitle String? // 建议封面标题
  suggestedCta        String? // 建议 CTA
  platformCopies      Json? // Record<PublishPlatform, PlatformCopy> - 各平台文案
  tags                Json? // string[] - 标签列表
  aiReasoning         String? // AI 决策推理记录
  provenance          Json? // BriefProvenance - 生成时的画像引用快照（需求 5.1,5.2,5.4）
  copyEdited          Boolean            @default(false) // 人工修改文案标记，自动流程不得静默覆盖（需求 2.3,2.8）
  planInputId         String? // 关联采纳的复盘建议输入 PlanGenerationInput.id（需求 1.7 反哺标注）
  renderMode          String             @default("MANUAL") @map("render_mode") // MANUAL | AUTO — 渲染模式（一键出片）
  autoGenStartedAt    DateTime?          @map("auto_gen_started_at") // 一键出片触发时间
  creationMode        CreationMode?      // 创作模式（null = 传统计划生成）
  sourceVideoUrl      String?            // 复刻爆款：源视频 URL
  sourceImageKeys     Json?              // string[] — 照片跟我动：源图 OSS keys
  textPrompt          String?            // 灵感生视频：文字描述
  selectedStyleId     String?            // 用户选定的风格 ID（成片工作室单选）
  selectedStyleAt     DateTime?          // 风格选定时间
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  store            Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contentPlan      ContentPlan?      @relation(fields: [contentPlanId], references: [id], onDelete: SetNull)
  playbook         Playbook?         @relation(fields: [playbookId], references: [id], onDelete: SetNull)
  shotTasks        ShotTask[]
  videoVariants    VideoVariant[]
  publishJobs      PublishJob[]
  complianceChecks ComplianceCheck[]
  metrics          PublishMetric[]

  @@index([storeId])
  @@index([scheduledDate])
  @@index([status])
  @@index([contentPlanId])
  @@map("content_briefs")
}

// ============ 拍摄任务 ============

/// 拍摄任务，单个镜头的拍摄指引
model ShotTask {
  id             String       @id @default(cuid())
  contentBriefId String
  order          Int // 镜头顺序，从 1 开始
  type           ShotTaskType
  title          String // max 20 chars，日常用语描述
  instruction    String // max 200 chars，日常用语拍摄指引
  examplePrompt  String? // Seedance prompt（仅 AI 补充时使用）
  durationSec    Int // 推荐拍摄时长，3-15 秒
  required       Boolean      @default(true)
  framingGuide   Json? // { angle: string, movement: string, tips: string } - 取景指导
  qualityRules   Json? // { needsAudio: boolean, minBrightness: number } - 质量要求
  status         String       @default("PENDING") // PENDING | CAPTURED | SKIPPED
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  contentBrief ContentBrief @relation(fields: [contentBriefId], references: [id], onDelete: Cascade)
  rawAssets    RawAsset[]

  @@index([contentBriefId])
  @@index([order])
  @@map("shot_tasks")
}

// ============ 原始素材 ============

/// 商家上传的原始素材（视频或图片），14 天过期策略
model RawAsset {
  id             String    @id @default(cuid())
  storeId        String
  shotTaskId     String?
  uploaderUserId String? // 上传者 userId
  type           String // VIDEO | IMAGE
  category       String? // PRODUCT | CHARACTER | OTHER（素材库分类；null 表示非素材库资产，如复刻临时下载的源视频）
  ossKey         String // OSS 存储路径
  url            String? // 签名 URL（临时，按需生成）
  filename       String?
  mimeType       String?
  sizeBytes      Int?
  durationSec    Float?
  width          Int?
  height         Int?
  thumbnailKey   String? // 缩略图 OSS 路径
  qualityScore   Float? // 0-100 质量评分
  qualityReport  Json? // QualityInspectionResult.report - 质量检测详细报告
  expiresAt      DateTime? // 14 天后过期，用于 asset-lifecycle-service 清理
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shotTask ShotTask? @relation(fields: [shotTaskId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([storeId, category]) // 素材库按分类筛选
  @@index([shotTaskId])
  @@index([expiresAt])
  @@map("raw_assets")
}

// ============ 视频版本 ============

/// AI 渲染生成的最终视频版本（促销版/氛围版/口播版等）
model VideoVariant {
  id             String           @id @default(cuid())
  contentBriefId String
  type           VideoVariantType
  title          String
  description    String?
  ossKey         String? // 视频 OSS 路径
  coverOssKey    String? // 封面图 OSS 路径
  durationSec    Float?
  width          Int?
  height         Int?
  subtitles      Json? // { text: string, startSec: number, endSec: number }[] - 字幕序列
  renderParams   Json? // FFmpeg 渲染参数记录
  generationLog  Json? // Seedance 生成调用记录
  regenScope     Json? // 上次局部重渲染的受影响分镜组集合（需求 4.5 追溯）
  score          Float? // AI 质量评分
  isSelected     Boolean          @default(false)
  styleLabel     String?          // 风格标签（如「快节奏种草」）
  styleProTags   Json?            // string[] — 优点标签
  styleConTags   Json?            // string[] — 缺点标签
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  contentBrief     ContentBrief      @relation(fields: [contentBriefId], references: [id], onDelete: Cascade)
  publishJobs      PublishJob[]
  complianceChecks ComplianceCheck[]

  @@index([contentBriefId])
  @@index([type])
  @@map("video_variants")
}

// ============ 发布任务 ============

/// 视频导出或发布的记录
model PublishJob {
  id             String           @id @default(cuid())
  contentBriefId String
  videoVariantId String?
  platform       PublishPlatform
  status         PublishJobStatus @default(DRAFT)
  title          String?
  caption        String?
  tags           Json?            // string[] - 发布标签
  locationText   String?          // 位置文本
  exportedOssKey String?          // 导出文件 OSS 路径
  errorMessage   String?
  accountId      String?          // 矩阵号发布目标账号（SocialAccount.id），null 表示主账号
  scheduledAt    DateTime?        // 定时发布时间，null 表示立即发布
  matrixBatchId  String?          // 矩阵分发批次 ID，同批次多个账号共享，便于追踪
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  publishedAt    DateTime?

  contentBrief ContentBrief  @relation(fields: [contentBriefId], references: [id], onDelete: Cascade)
  videoVariant VideoVariant? @relation(fields: [videoVariantId], references: [id], onDelete: SetNull)

  @@index([contentBriefId])
  @@index([platform])
  @@index([status])
  @@index([matrixBatchId])
  @@index([scheduledAt])
  @@map("publish_jobs")
}

// ============ 发布数据指标 ============

/// 视频在各平台的表现数据（手动录入或 API 同步）
model PublishMetric {
  id             String          @id @default(cuid())
  contentBriefId String
  platform       PublishPlatform
  publishJobId   String?
  views          Int             @default(0)
  likes          Int             @default(0)
  comments       Int             @default(0)
  shares         Int             @default(0)
  saves          Int             @default(0)
  profileVisits  Int             @default(0)
  linkClicks     Int             @default(0)
  messages       Int             @default(0)
  orders         Int             @default(0)
  redemptions    Int             @default(0)
  revenueCents   Int             @default(0) // 收入，分为单位
  source         String          @default("MANUAL") // MANUAL | API_SYNC
  capturedAt     DateTime        @default(now())
  createdAt      DateTime        @default(now())

  contentBrief ContentBrief @relation(fields: [contentBriefId], references: [id], onDelete: Cascade)

  @@index([contentBriefId])
  @@index([platform])
  @@index([capturedAt])
  @@map("publish_metrics")
}

// ============ 合规检查 ============

/// 合规检查记录，包含风险等级和问题列表
model ComplianceCheck {
  id             String              @id @default(cuid())
  contentBriefId String
  videoVariantId String?
  riskLevel      ComplianceRiskLevel
  issues         Json // ComplianceIssue[] - 合规问题列表
  suggestions    Json? // string[] - 修复建议
  blockedReasons Json? // string[] - 阻断原因（riskLevel=BLOCKED 时）
  passed         Boolean             @default(false)
  acknowledgedAt DateTime? // 用户确认时间（HIGH 风险时用户确认后方可导出）
  createdAt      DateTime            @default(now())

  contentBrief ContentBrief  @relation(fields: [contentBriefId], references: [id], onDelete: Cascade)
  videoVariant VideoVariant? @relation(fields: [videoVariantId], references: [id], onDelete: SetNull)

  @@index([contentBriefId])
  @@index([videoVariantId])
  @@index([riskLevel])
  @@map("compliance_checks")
}

// ============ 出镜授权 ============

/// 出镜授权记录，顾客或员工的肖像使用授权
model ConsentRecord {
  id          String    @id @default(cuid())
  storeId     String
  personName  String?
  personRole  String? // CUSTOMER | STAFF | OWNER
  consentType String // APPEARANCE | VOICE
  consentText String // 授权文本
  assetOssKey String? // 签署授权书扫描件 OSS 路径
  validFrom   DateTime  @default(now())
  validTo     DateTime? // 授权有效期截止，null 表示永久有效
  createdAt   DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([validTo])
  @@map("consent_records")
}

// ============ 发布账号（第一阶段预留，暂不实现自动发布） ============

/// 门店绑定的社交平台发布账号（预留）
model SocialAccount {
  id             String          @id @default(cuid())
  storeId        String
  platform       PublishPlatform
  accountName    String?
  externalUserId String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([platform])
  @@map("social_accounts")
}

// ============ 本地生活深化改造（三件套反馈控制回路）新增表 ============
// 均为 additive-only：独立新表，不修改/删除既有表与列

/// 复盘建议固化为下一轮内容计划生成输入（需求 1.3,1.7）
/// 由 performance-learning-service.applyInsights 写入，content-calendar-service 一次性消费
model PlanGenerationInput {
  id                String    @id @default(cuid())
  storeId           String
  acceptedNextGoals Json? // ContentGoal[] - 采纳的推荐下周目标
  reusePlaybookIds  Json? // string[] - 提升复用权重的剧本
  avoidPlaybookIds  Json? // string[] - 规避名单
  acceptedSummaries Json // string[] - 用于计划“已采纳上轮复盘建议:<摘要>”标注
  stylePreference   Json? // { preferredStyleIds: string[], avoidedStyleIds: string[] } — 风格偏好反哺
  consumedAt        DateTime? // 被某次 content-plan 生成消费的时间（一次性）
  createdAt         DateTime  @default(now())

  @@index([storeId])
  @@index([consumedAt])
  @@map("plan_generation_inputs")
}

/// 平台账号会话凭证（需求 7.3,7.4）—— cookie 加密存储，仅抓取商家本人账号数据
model PlatformAccount {
  id              String          @id @default(cuid())
  storeId         String
  platform        PublishPlatform
  encryptedCookie String // 服务端加密后的会话凭证，禁止明文/禁止入 Git
  authConfirmed   Boolean         @default(false) // 风险告知后的授权确认（需求 7.2）
  status          String          @default("ACTIVE") // ACTIVE | NEEDS_RELINK（需求 7.6）
  lastCrawledAt   DateTime? // 抓取频率门控（需求 7.5）
  crawlIntervalH  Int             @default(24) // 6-24h 可配置
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([storeId, platform])
  @@index([status])
  @@index([lastCrawledAt])
  @@map("platform_accounts")
}

/// 待发布清单（需求 8.1,8.2,8.4）—— 导出成功后加入，记录各平台发布状态
model PublishQueueItem {
  id                 String   @id @default(cuid())
  storeId            String
  contentBriefId     String
  videoVariantId     String
  exportedAt         DateTime @default(now())
  remindAfterH       Int      @default(24) // 超时提醒时长（需求 8.3 可配置）
  reminded           Boolean  @default(false)
  publishedPlatforms Json     @default("[]") // { platform, publishedAt }[]（需求 8.4）
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([videoVariantId]) // 幂等保证：每个已导出 variant 恰对应一个 PublishQueueItem（防并发创建重复）
  @@index([storeId])
  @@index([contentBriefId])
  @@index([reminded, exportedAt])
  @@map("publish_queue_items")
}

/// 门店作用域通知中心（需求 9.3）—— 已读/未读，承接过期/发布/抓取失效/里程碑提醒
/// 注：与既有 user 作用域 Notification 区分，命名为 StoreNotification（映射表 store_notifications）
model StoreNotification {
  id         String   @id @default(cuid())
  storeId    String
  type       String // EXPIRY | PUBLISH_REMINDER | CRAWL_FAILED | MILESTONE
  title      String
  body       String
  actionHref String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([storeId, read])
  @@index([createdAt])
  @@map("store_notifications")
}

/// 计划某天锁定/跳过状态（需求 6.5）—— 下一轮自动生成尊重该状态
model CalendarDayState {
  id        String   @id @default(cuid())
  storeId   String
  date      DateTime
  state     String   @default("NORMAL") // NORMAL | LOCKED | SKIPPED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, date])
  @@index([storeId])
  @@map("calendar_day_states")
}

/// 连续创作/里程碑记录（需求 11.1,11.2）—— 每门店一条
model StreakRecord {
  id             String    @id @default(cuid())
  storeId        String    @unique
  currentDays    Int       @default(0)
  currentWeeks   Int       @default(0)
  lastActiveDate DateTime?
  milestones     Json      @default("[]") // 已达成里程碑标识[]
  updatedAt      DateTime  @updatedAt

  @@map("streak_records")
}

// ================================================================
// ============ 对话式 C 端（Studio）新增枚举与模型 ============
// ============ (additive-only：独立新表，不修改/删除既有表结构) ============
// ================================================================

/// 对话模式：对应 Inhot 四种生成模式 + 商家技能
enum ConversationMode {
  REPLICATE // 复刻爆款
  SHORTFILM // 沉浸式短片
  IDEA2VIDEO // 输入灵感生视频（文生视频）
  PHOTO2MOTION // 照片跟我动（图生视频）
  MERCHANT // 商家经营技能
}

/// 对话消息角色
enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

/// 对话会话：承载一次连续的对话式创作上下文，关联现有 User
model Conversation {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  title     String? // 会话标题，可由首条消息或意图自动生成
  mode      ConversationMode @default(REPLICATE)
  meta      Json? // 软关联信息（如 storeId、当前收集的槽位），不加外键
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
  projects Project[] // 本会话触发生成的底层项目（来源标记）

  @@index([userId])
  @@map("conversations")
}

/// 对话消息：用户/助手/系统消息，attachments 存图片/链接，actionRefs 关联产生的实体
model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           ChatRole
  content        String // 文本内容
  attachments    Json? // 附件：{ images?: string[], links?: string[] }
  actionRefs     Json?    @map("action_refs") // 关联实体：{ projectId?, contentBriefId?, jobId? }
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("chat_messages")
}
