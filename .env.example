# Database
DATABASE_URL="file:./dev.db"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication
JWT_SECRET="your-jwt-secret-change-in-production"

# 平台账号会话凭证加密密钥（platform-metrics-crawler 用于 AES-256-GCM 加密商家平台 cookie）
# 缺失时凭证加解密会直接抛错（禁止明文存储凭证、禁止使用默认回退密钥）
PLATFORM_CRED_ENC_KEY="your-platform-credential-encryption-key-change-in-production"

# 火山引擎方舟平台（Seedance 2.0 视频生成官方 API）
# 从 console.volcengine.com 方舟后台获取 API Key
SEEDANCE_API_KEY="ark-your-api-key"
SEEDANCE_API_URL="https://ark.cn-beijing.volces.com/api/v3"

# 视频多模态分析（视频直传分析为分镜脚本）
# 推荐模型：doubao-seed-2-0-pro-260215（火山方舟，Video-MME-v2 排名 #3，视频理解能力优于 Qwen-VL-Max）
# 备选模型：qwen-vl-max（阿里云百炼 DashScope，成本低但视频理解能力弱一档）
# 必填：缺失任一项 video-analyzer.ts 将直接抛错（真实接口、无降级）
# VISION_API_URL：OpenAI 兼容接口基址（火山方舟示例：https://ark.cn-beijing.volces.com/api/v3）
VISION_API_URL=""
# VISION_API_KEY：上述接口的鉴权密钥（火山方舟与 Seedance 共用同一个 ark-* key）
VISION_API_KEY=""
# VISION_MODEL：支持视频输入的多模态模型名（推荐 doubao-seed-2-0-pro-260215，备选 qwen-vl-max）
VISION_MODEL=""

# Object Storage (阿里云 OSS)
OSS_REGION=""
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""
OSS_BUCKET=""
OSS_ENDPOINT=""
OSS_CDN_DOMAIN=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3011"
NODE_ENV="development"

# 场景检测阈值（0-1，默认 0.32；快剪视频可降低，慢镜头可提高）
SCENE_THRESHOLD="0.32"

# WaveSpeed AI Video Upscaler（视频超分服务）
# 从 https://wavespeed.ai 获取 API Key
WAVESPEED_API_KEY=""
WAVESPEED_API_BASE_URL="https://api.wavespeed.ai/api/v3"

# 阿里云百炼 DashScope（HappyHorse V-Edit 视频编辑模型）
# 从 https://dashscope.console.aliyun.com 获取 API Key
# HappyHorse 模式必须配置，缺失时调用会直接抛错
DASHSCOPE_API_KEY=""
# HappyHorse 积分系数（平台加成，默认 1.5）
HAPPYHORSE_CREDIT_COEFFICIENT="1.5"

# 商家营销平台 LLM（文案润色，OpenAI 兼容接口，qwen 模型）
# 可选：未配置时回退到 VISION_API_URL/KEY 或 DASHSCOPE_API_KEY
# 推荐模型：qwen-plus（阿里云百炼 DashScope）
MERCHANT_LLM_API_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
MERCHANT_LLM_API_KEY=""
MERCHANT_LLM_MODEL="qwen-plus"
